SELECT
    SPLIT_PART(APPLICATION_IDENTIFIER, '|', 1) AS APPLICATION_PREFIX,
    COUNT(*) AS RECORD_COUNT,
    COUNT(DISTINCT APPLICATION_IDENTIFIER) AS DISTINCT_APPLICATION_COUNT,
    COUNT(DISTINCT ACCOUNT_NUMBER) AS DISTINCT_ACCOUNT_COUNT
FROM FDP_UK_CARDS_DB.CREDIT_CARD_ACCOUNT
WHERE ACTIVE = '1'
  AND APPLICATION_IDENTIFIER IS NOT NULL
GROUP BY 1
ORDER BY RECORD_COUNT DESC;