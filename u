SELECT
    SPLIT_PART(APPLICATION_IDENTIFIER, '|', 1) AS source_prefix,
    COUNT(*) AS record_count,
    COUNT_IF(LENGTH(SPLIT_PART(APPLICATION_IDENTIFIER, '|', 2)) > 10)
        AS long_id_count,
    COUNT_IF(LENGTH(SPLIT_PART(APPLICATION_IDENTIFIER, '|', 2)) <= 10)
        AS short_id_count
FROM FDP_UK_CARDS_DB.CREDIT_CARD_ACCOUNT
WHERE ACTIVE = '1'
  AND APPLICATION_IDENTIFIER IS NOT NULL
GROUP BY 1
ORDER BY record_count DESC;