LEFT JOIN BDP_UK_CARDS.DIM_REFERENCE ref_prod
    ON ref_prod.REFERENCE_DETAIL_NAME =
        CASE
            WHEN a.TRANSACTION_PURPOSE_CODE IN ('DPNGCB', 'NGCBRF') THEN 'NGCB'
            WHEN a.TRANSACTION_PURPOSE_CODE IN ('RL_BLD','RH_BLD','FL_BLD','FH_BLD','IH_BLD','IL_BLD') THEN 'Triumph'
            ELSE 'Others'
        END
   AND ref_prod.ACTIVE = '1'
   AND ref_prod.REFERENCE_CATEGORY_CODE = 10010