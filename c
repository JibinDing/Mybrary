DECLARE
    v_reload_start TIMESTAMP;
BEGIN

    SELECT COALESCE(
        DATEADD(hour, -119, MAX(REPORT_HOUR)),
        DATEADD(hour, -120, CURRENT_TIMESTAMP())
    )
    INTO :v_reload_start
    FROM BDP_UK_CARDS.FACT_SMARTPAY_TRANSACTION_SUMMARY;


DELETE FROM BDP_UK_CARDS.FACT_SMARTPAY_TRANSACTION_SUMMARY
WHERE REPORT_HOUR >= :v_reload_start;


WITH latest_status AS (
    SELECT *
    FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS
    WHERE SOURCE_CHANGE_TIMESTAMP >= :v_reload_start
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY TRANSACTION_IDENTIFIER
        ORDER BY SOURCE_CHANGE_TIMESTAMP DESC
    ) = 1
)