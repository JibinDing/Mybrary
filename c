WHEN s.TRANSACTION_STATUS_CODE = 'AUTHORISATION_REQUIRED'
    THEN 'DROPOUT_AUTHORISATION_REQUIRED'
WHEN s.TRANSACTION_STATUS_CODE = 'CARD_DETAILS_REQUIRED'
    THEN 'DROPOUT_CARD_DETAILS_REQUIRED'
WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_AUTHORISED'
    THEN 'DROPOUT_PAYMENT_AUTHORISED'
WHEN s.TRANSACTION_STATUS_CODE = 'AUTHENTICATION_REQUIRED'
    THEN 'DROPOUT_AUTHENTICATION_REQUIRED'
WHEN s.TRANSACTION_STATUS_CODE = 'CARD_DETAILS'
    THEN 'DROPOUT_CARD_DETAILS'