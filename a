-- Check data loaded

SELECT COUNT(*)
FROM BDP_UK_CARDS.FACT_SUMMARY_SMART_PAY_TRANSACTIONS;

-- Check latest timestamp

SELECT MAX(REPORT_TIMESTAMP)
FROM BDP_UK_CARDS.FACT_SUMMARY_SMART_PAY_TRANSACTIONS;

-- Check Reporting Only statuses

SELECT
    TRANSACTION_STATUS_KEY,
    COUNT(*)
FROM BDP_UK_CARDS.FACT_SUMMARY_SMART_PAY_TRANSACTIONS
GROUP BY 1
ORDER BY 1;

-- Check task execution history

SELECT *
FROM TABLE(
    INFORMATION_SCHEMA.TASK_HISTORY(
        TASK_NAME=>'SMARTPAY_LOAD_TASK'
    )
)
ORDER BY SCHEDULED_TIME DESC;