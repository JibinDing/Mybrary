-- Set context as needed
USE ROLE PROD_BUK_SNSVC0073314_CREATOR_FR;
USE WAREHOUSE PROD_BUK_SNSVC0073314_ELT_WH;
USE DATABASE PROD_BUK_SNSVC0073314_CARDS_BUSINESS_DB;
USE SCHEMA BDP_UK_CARDS;

CREATE OR REPLACE PROCEDURE SP_SMARTPAY_REFRESH()
RETURNS VARCHAR
LANGUAGE SQL
EXECUTE AS OWNER
AS
$$
BEGIN

    DELETE FROM BDP_UK_CARDS.FACT_SUMMARY_SMART_PAY_TRANSACTIONS
    WHERE REPORT_TIMESTAMP >= DATEADD(hour, -120, CURRENT_TIMESTAMP());

    INSERT INTO BDP_UK_CARDS.FACT_SUMMARY_SMART_PAY_TRANSACTIONS
    WITH latest_status AS (
        SELECT *
        FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS
        WHERE SOURCE_CHANGE_TIMESTAMP >= DATEADD(hour, -120, CURRENT_TIMESTAMP())
        QUALIFY ROW_NUMBER() OVER (
            PARTITION BY TRANSACTION_IDENTIFIER
            ORDER BY SOURCE_CHANGE_TIMESTAMP DESC
        ) = 1
    )
    SELECT
        'SMARTPAY_TRANSACTION' AS METRIC_IDENTIFIER,

        CAST(DATE_TRUNC('HOUR', s.SOURCE_CHANGE_TIMESTAMP) AS DATE) AS REPORT_DATE,
        DATE_TRUNC('HOUR', s.SOURCE_CHANGE_TIMESTAMP) AS REPORT_TIMESTAMP,

        COALESCE(s.SOURCE_SYSTEM_KEY, a.SOURCE_SYSTEM_KEY) AS SOURCE_SYSTEM_KEY,

        CASE
            WHEN a.TRANSACTION_CHANNEL_CODE = 106 THEN 'ROLB'
            WHEN a.TRANSACTION_CHANNEL_CODE = 206 THEN 'BMB'
            WHEN a.TRANSACTION_CHANNEL_CODE = 406 THEN 'AS2'
            WHEN a.TRANSACTION_CHANNEL_CODE = 506 THEN 'FSV'
            WHEN a.TRANSACTION_CHANNEL_CODE = 706 THEN 'IVR'
            WHEN a.TRANSACTION_CHANNEL_CODE = 999 THEN 'OTHER'
            ELSE 'UNKNOWN'
        END AS TRANSACTION_CHANNEL_KEY,

        CASE
            WHEN a.TRANSACTION_PURPOSE_CODE IN ('DPNGCB', 'NGCBRF') THEN 'NGCB'
            WHEN a.TRANSACTION_PURPOSE_CODE IN (
                'RL_BLD', 'RH_BLD', 'FL_BLD',
                'FH_BLD', 'IH_BLD', 'IL_BLD'
            ) THEN 'TRIUMPH'
            ELSE 'UNKNOWN'
        END AS PRODUCT_GROUP_KEY,

        CASE
            WHEN s.TRANSACTION_STATUS_CODE IN ('PAYMENT_CAPTURED', 'POSTED')
                THEN 'SUCCESS'
            WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_DECLINED'
                THEN 'DECLINED'
            WHEN s.TRANSACTION_STATUS_CODE IN (
                'AUTHORISATION_REQUIRED',
                'CARD_DETAILS_REQUIRED',
                'PAYMENT_AUTHORISED',
                'AUTHENTICATION_REQUIRED',
                'CARD_DETAILS'
            )
                THEN 'DROPOUT'
            WHEN s.TRANSACTION_STATUS_CODE = 'FAIL'
                THEN 'REPORTING_ONLY_FAIL'
            WHEN s.TRANSACTION_STATUS_CODE = 'AUTH_FAIL'
                THEN 'REPORTING_ONLY_AUTH_FAIL'
            WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_FAILED'
                THEN 'REPORTING_ONLY_PAYMENT_FAILED'
            WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_CANCELLED'
                THEN 'REPORTING_ONLY_PAYMENT_CANCELLED'
            ELSE 'UNKNOWN'
        END AS TRANSACTION_STATUS_KEY,

        s.ERROR_DESCRIPTION AS ERROR_MESSAGE_DESCRIPTION,
        COUNT(DISTINCT a.TRANSACTION_IDENTIFIER) AS MEASURE_VOLUME,
        SUM(a.TRANSACTION_AMOUNT) AS MEASURE_VALUE

    FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_AUTHORIZATION_TRANSACTION a
    JOIN latest_status s
        ON a.TRANSACTION_IDENTIFIER = s.TRANSACTION_IDENTIFIER

    WHERE s.TRANSACTION_STATUS_CODE NOT IN (
        'DUPLICATE_POSTED_TRAN',
        'GATHER_BROWSER_INFO',
        'VALIDATION_FAILED',
        'DIARY_NOTE_MADE'
    )

    GROUP BY ALL;

    RETURN 'SP_SMARTPAY_REFRESH completed successfully';

END;
$$;