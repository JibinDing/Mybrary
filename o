WITH agg AS (
    SELECT
        application_id AS short_application_id,
        final_status
    FROM <AGGREGATOR_BDP_TABLE>
    WHERE final_status IN ('ACCEPT', 'COMPLETE')
),

ngcb_map AS (
    SELECT
        caseid,
        applicationid AS long_application_id
    FROM e_ngcb_apply_db.application_results_sum_caselig_main
),

fdp_app AS (
    SELECT
        application_number,
        application_identifier
    FROM FDP_UK_CARDS_DB.CREDIT_CARD_APPLICATION
),

fdp_account AS (
    SELECT
        account_number,
        account_identifier,
        application_identifier
    FROM FDP_UK_CARDS_DB.CREDIT_CARD_ACCOUNT
    WHERE active = '1'
)

SELECT
    agg.short_application_id,
    agg.final_status,
    ngcb_map.long_application_id,
    fdp_app.application_identifier,
    fdp_account.account_number,
    fdp_account.account_identifier
FROM agg
LEFT JOIN ngcb_map
    ON ngcb_map.caseid = agg.short_application_id
LEFT JOIN fdp_app
    ON fdp_app.application_number = ngcb_map.long_application_id
LEFT JOIN fdp_account
    ON fdp_account.application_identifier = fdp_app.application_identifier;