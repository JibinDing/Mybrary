SELECT COUNT(*) AS status_rows_last_1_day
FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS
WHERE SOURCE_CHANGE_TIMESTAMP >= (
    SELECT DATEADD(day, -1, MAX(SOURCE_CHANGE_TIMESTAMP))
    FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS
);


SELECT
    COUNT(*) AS status_rows_last_1_day,
    COUNT(a.TRANSACTION_IDENTIFIER) AS matched_auth_rows
FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS s
LEFT JOIN FDP_UK_CARDS_DB.PAYMENT_GATEWAY_AUTHORIZATION_TRANSACTION a
    ON a.TRANSACTION_IDENTIFIER = s.TRANSACTION_IDENTIFIER
WHERE s.SOURCE_CHANGE_TIMESTAMP >= (
    SELECT DATEADD(day, -1, MAX(SOURCE_CHANGE_TIMESTAMP))
    FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS
);