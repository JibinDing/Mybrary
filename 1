SELECT
    'SMARTPAY_TRANSACTION' AS METRIC_IDENTIFIER,

    CAST(s.SOURCE_CHANGE_TIMESTAMP AS DATE) AS REPORT_DATE,
    s.SOURCE_CHANGE_TIMESTAMP AS REPORT_TIMESTAMP,

    COALESCE(s.SOURCE_SYSTEM_KEY, a.SOURCE_SYSTEM_KEY) AS SOURCE_SYSTEM_KEY,

    CASE
        WHEN a.DELIVERY_CHANNEL_CODE = 106 THEN 'ROLB'
        WHEN a.DELIVERY_CHANNEL_CODE = 206 THEN 'BMB'
        WHEN a.DELIVERY_CHANNEL_CODE = 406 THEN 'AS2'
        WHEN a.DELIVERY_CHANNEL_CODE = 506 THEN 'FSV'
        WHEN a.DELIVERY_CHANNEL_CODE = 706 THEN 'IVR'
        WHEN a.DELIVERY_CHANNEL_CODE = 999 THEN 'OTHER'
        ELSE 'UNKNOWN'
    END AS TRANSACTION_CHANNEL_KEY,

    CASE
        WHEN a.TRANSACTION_PURPOSE_CODE IN ('DPNGCB', 'NGCBRF') THEN 'NGCB'
        WHEN a.TRANSACTION_PURPOSE_CODE IN (
            'RL_BLD', 'RH_BLD', 'FL_BLD',
            'FH_BLD', 'IH_BLD', 'IL_BLD'
        ) THEN 'TRIUMPH'
        ELSE 'UNKNOWN'
    END AS PRODUCT_GROUP_KEY,

    CASE
        WHEN s.TRANSACTION_STATUS_CODE IN ('PAYMENT_CAPTURED', 'POSTED') THEN 'SUCCESS'
        WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_DECLINED' THEN 'DECLINED'
        WHEN s.TRANSACTION_STATUS_CODE IN (
            'AUTHORISATION_REQUIRED',
            'CARD_DETAILS_REQUIRED',
            'DUPLICATE_POSTED_TRAN',
            'FAIL',
            'GATHER_BROWSER_INFO',
            'PAYMENT_AUTHORISED',
            'VALIDATION_FAILED',
            'AUTHENTICATION_REQUIRED',
            'AUTH_FAIL',
            'DIARY_NOTE_MADE',
            'PAYMENT_FAILED',
            'PAYMENT_CANCELLED'
        ) THEN 'DROPOUT'
        ELSE 'UNKNOWN'
    END AS TRANSACTION_STATUS_KEY,

    s.ERROR_DESCRIPTION AS ERROR_MESSAGE,

    COUNT(DISTINCT a.TRANSACTION_IDENTIFIER) AS MEASURE_VOLUME,
    SUM(a.TRANSACTION_AMOUNT) AS MEASURE_VALUE

FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_AUTHORIZATION_TRANSACTION a

LEFT JOIN FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS s
    ON a.TRANSACTION_IDENTIFIER = s.TRANSACTION_IDENTIFIER

GROUP BY
    CAST(s.SOURCE_CHANGE_TIMESTAMP AS DATE),
    s.SOURCE_CHANGE_TIMESTAMP,
    COALESCE(s.SOURCE_SYSTEM_KEY, a.SOURCE_SYSTEM_KEY),

    CASE
        WHEN a.DELIVERY_CHANNEL_CODE = 106 THEN 'ROLB'
        WHEN a.DELIVERY_CHANNEL_CODE = 206 THEN 'BMB'
        WHEN a.DELIVERY_CHANNEL_CODE = 406 THEN 'AS2'
        WHEN a.DELIVERY_CHANNEL_CODE = 506 THEN 'FSV'
        WHEN a.DELIVERY_CHANNEL_CODE = 706 THEN 'IVR'
        WHEN a.DELIVERY_CHANNEL_CODE = 999 THEN 'OTHER'
        ELSE 'UNKNOWN'
    END,

    CASE
        WHEN a.TRANSACTION_PURPOSE_CODE IN ('DPNGCB', 'NGCBRF') THEN 'NGCB'
        WHEN a.TRANSACTION_PURPOSE_CODE IN (
            'RL_BLD', 'RH_BLD', 'FL_BLD',
            'FH_BLD', 'IH_BLD', 'IL_BLD'
        ) THEN 'TRIUMPH'
        ELSE 'UNKNOWN'
    END,

    CASE
        WHEN s.TRANSACTION_STATUS_CODE IN ('PAYMENT_CAPTURED', 'POSTED') THEN 'SUCCESS'
        WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_DECLINED' THEN 'DECLINED'
        WHEN s.TRANSACTION_STATUS_CODE IN (
            'AUTHORISATION_REQUIRED',
            'CARD_DETAILS_REQUIRED',
            'DUPLICATE_POSTED_TRAN',
            'FAIL',
            'GATHER_BROWSER_INFO',
            'PAYMENT_AUTHORISED',
            'VALIDATION_FAILED',
            'AUTHENTICATION_REQUIRED',
            'AUTH_FAIL',
            'DIARY_NOTE_MADE',
            'PAYMENT_FAILED',
            'PAYMENT_CANCELLED'
        ) THEN 'DROPOUT'
        ELSE 'UNKNOWN'
    END,

    s.ERROR_DESCRIPTION;