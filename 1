SELECT
    MAX(s.SOURCE_CHANGE_TIMESTAMP) AS latest_matched_status_ts
FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS s
JOIN FDP_UK_CARDS_DB.PAYMENT_GATEWAY_AUTHORIZATION_TRANSACTION a
    ON a.TRANSACTION_IDENTIFIER = s.TRANSACTION_IDENTIFIER;

WHERE s.SOURCE_CHANGE_TIMESTAMP >= (
    SELECT DATEADD(hour, -4, MAX(s.SOURCE_CHANGE_TIMESTAMP))
    FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS s
    JOIN FDP_UK_CARDS_DB.PAYMENT_GATEWAY_AUTHORIZATION_TRANSACTION a
        ON a.TRANSACTION_IDENTIFIER = s.TRANSACTION_IDENTIFIER
)