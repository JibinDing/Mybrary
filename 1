WITH txn_timeline AS (

    SELECT
        a.TRANSACTION_IDENTIFIER,

        MIN(a.SOURCE_INSERT_TIMESTAMP) AS auth_first_ts,

        MIN(
            CASE
                WHEN s.TRANSACTION_STATUS_CODE IN (
                    'PAYMENT_CAPTURED',
                    'POSTED',
                    'PAYMENT_DECLINED',
                    'AUTHORISATION_REQUIRED',
                    'CARD_DETAILS_REQUIRED',
                    'PAYMENT_AUTHORISED',
                    'AUTHENTICATION_REQUIRED',
                    'CARD_DETAILS',
                    'FAIL',
                    'AUTH_FAIL',
                    'PAYMENT_FAILED',
                    'PAYMENT_CANCELLED'
                )
                THEN s.SOURCE_CHANGE_TIMESTAMP
            END
        ) AS terminal_status_ts

    FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_AUTHORIZATION_TRANSACTION a

    JOIN FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS s
        ON a.TRANSACTION_IDENTIFIER = s.TRANSACTION_IDENTIFIER

    GROUP BY a.TRANSACTION_IDENTIFIER
)

SELECT
    COUNT(*) AS matched_transactions,

    MAX(
        DATEDIFF(
            'minute',
            auth_first_ts,
            terminal_status_ts
        )
    ) AS max_completion_minutes,

    AVG(
        DATEDIFF(
            'minute',
            auth_first_ts,
            terminal_status_ts
        )
    ) AS avg_completion_minutes

FROM txn_timeline
WHERE terminal_status_ts IS NOT NULL;