SELECT
    TRANSACTION_STATUS_KEY,
    COUNT(*) AS ROW_COUNT
FROM BDP_UK_CARDS.FACT_SUMMARY_SMART_PAY_TRANSACTIONS_DEV
GROUP BY TRANSACTION_STATUS_KEY
ORDER BY ROW_COUNT DESC;



SELECT
    s.TRANSACTION_STATUS_CODE,
    CASE
        WHEN s.TRANSACTION_STATUS_CODE IN ('PAYMENT_CAPTURED', 'POSTED')
            THEN 'SUCCESS'

        WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_DECLINED'
            THEN 'DECLINED'

        WHEN s.TRANSACTION_STATUS_CODE IN (
            'AUTHORISATION_REQUIRED',
            'CARD_DETAILS_REQUIRED',
            'PAYMENT_AUTHORISED',
            'AUTHENTICATION_REQUIRED',
            'CARD_DETAILS'
        )
            THEN 'DROPOUT'

        WHEN s.TRANSACTION_STATUS_CODE IN (
            'DUPLICATE_POSTED_TRAN',
            'GATHER_BROWSER_INFO',
            'VALIDATION_FAILED',
            'DIARY_NOTE_MADE'
        )
            THEN 'IGNORE'

        WHEN s.TRANSACTION_STATUS_CODE IN (
            'FAIL',
            'AUTH_FAIL',
            'PAYMENT_FAILED',
            'PAYMENT_CANCELLED'
        )
            THEN 'REPORTING_ONLY'

        ELSE 'UNKNOWN'
    END AS DERIVED_STATUS,
    COUNT(*) AS CNT
FROM FDP_UK_CARDS_DB.PAYMENT_GATEWAY_TRANSACTION_STATUS s
GROUP BY 1,2
ORDER BY CNT DESC;