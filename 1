WITH smartpay_txn AS (
    SELECT DISTINCT txn_ref
    FROM e_smartpay_db.to_txn_aud
    WHERE txn_prs_cde IN (
        'DPNGCB', 'NGCBRF',
        'RL_BLD', 'RH_BLD',
        'FL_BLD', 'FH_BLD',
        'IH_BLD', 'IL_BLD'
    )
),

txn_timeline AS (

    SELECT
        s.txn_ref,

        MIN(s.ins_tmp) AS first_status_ts,

        MIN(
            CASE
                WHEN s.txn_sts IN (
                    'PAYMENT_CAPTURED',
                    'POSTED',
                    'PAYMENT_DECLINED'
                )
                THEN s.ins_tmp
            END
        ) AS terminal_status_ts

    FROM e_smartpay_db.to_txn_aud_sts s

    JOIN smartpay_txn t
        ON s.txn_ref = t.txn_ref

    GROUP BY s.txn_ref
)

SELECT
    COUNT(*) AS txn_count,

    MAX(
        (
            unix_timestamp(terminal_status_ts)
            - unix_timestamp(first_status_ts)
        ) / 60
    ) AS max_completion_minutes,

    AVG(
        (
            unix_timestamp(terminal_status_ts)
            - unix_timestamp(first_status_ts)
        ) / 60
    ) AS avg_completion_minutes

FROM txn_timeline
WHERE terminal_status_ts IS NOT NULL;