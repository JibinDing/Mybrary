CASE

    WHEN s.TRANSACTION_STATUS_CODE IN ('PAYMENT_CAPTURED', 'POSTED')
        THEN 'SUCCESS'

    WHEN s.TRANSACTION_STATUS_CODE = 'PAYMENT_DECLINED'
        THEN 'DECLINED'

    WHEN s.TRANSACTION_STATUS_CODE IN (
        'AUTHORISATION_REQUIRED',
        'CARD_DETAILS_REQUIRED',
        'PAYMENT_AUTHORISED',
        'AUTHENTICATION_REQUIRED',
        'CARD_DETAILS'
    )
        THEN 'DROPOUT'

    WHEN s.TRANSACTION_STATUS_CODE IN (
        'DUPLICATE_POSTED_TRAN',
        'GATHER_BROWSER_INFO',
        'VALIDATION_FAILED',
        'DIARY_NOTE_MADE'
    )
        THEN 'IGNORE'

    WHEN s.TRANSACTION_STATUS_CODE IN (
        'FAIL',
        'AUTH_FAIL',
        'PAYMENT_FAILED',
        'PAYMENT_CANCELLED'
    )
        THEN 'REPORTING_ONLY'

    ELSE 'UNKNOWN'

END AS TRANSACTION_STATUS_KEY