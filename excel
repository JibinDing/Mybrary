Sub GroupSimilarReports()
    Dim wsData As Worksheet, wsResult As Worksheet
    Dim dictReports As Object
    Dim i As Long, lastRow As Long
    Dim reportName As String, attribute As String
    Dim threshold As Integer
    threshold = 4
    
    Set wsData = ThisWorkbook.Sheets("Attribute by Report")
    
    On Error Resume Next
    Set wsResult = ThisWorkbook.Sheets("Grouped Reports")
    On Error GoTo 0
    If wsResult Is Nothing Then
        Set wsResult = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
        wsResult.Name = "Grouped Reports"
    Else
        wsResult.Cells.Clear
    End If
    
    Set dictReports = CreateObject("Scripting.Dictionary")
    lastRow = wsData.Cells(wsData.Rows.Count, "A").End(xlUp).Row
    
    For i = 2 To lastRow
        reportName = Trim(wsData.Cells(i, 2).Value)
        attribute = Trim(wsData.Cells(i, 7).Value)
        If reportName <> "" And attribute <> "" Then
            If Not dictReports.Exists(reportName) Then
                dictReports(reportName) = CreateObject("Scripting.Dictionary")
            End If
            dictReports(reportName)(attribute) = 1
        End If
    Next i
    
    Dim reports() As String
    reports = dictReports.Keys
    Dim n As Integer
    n = UBound(reports) + 1
    
    Dim groupID() As Integer
    ReDim groupID(n - 1)
    Dim nextGroup As Integer
    nextGroup = 1
    
    Dim j As Integer, k As Integer
    Dim diffCount As Integer
    Dim attr As Variant
    
    For j = 0 To n - 1
        If groupID(j) = 0 Then
            groupID(j) = nextGroup
            nextGroup = nextGroup + 1
        End If
        For k = j + 1 To n - 1
            If groupID(k) = 0 Then
                diffCount = 0
                For Each attr In dictReports(reports(j)).Keys
                    If Not dictReports(reports(k)).Exists(attr) Then
                        diffCount = diffCount + 1
                    End If
                Next attr
                For Each attr In dictReports(reports(k)).Keys
                    If Not dictReports(reports(j)).Exists(attr) Then
                        diffCount = diffCount + 1
                    End If
                Next attr
                If diffCount <= threshold Then
                    groupID(k) = groupID(j)
                End If
            End If
        Next k
    Next j
    
    wsResult.Cells(1, 1).Value = "Group"
    wsResult.Cells(1, 2).Value = "Report Name"
    wsResult.Cells(1, 3).Value = "Attribute Count"
    
    Dim outputRow As Integer
    outputRow = 2
    Dim g As Integer
    For g = 1 To nextGroup - 1
        For j = 0 To n - 1
            If groupID(j) = g Then
                wsResult.Cells(outputRow, 1).Value = "Group " & g
                wsResult.Cells(outputRow, 2).Value = reports(j)
                wsResult.Cells(outputRow, 3).Value = dictReports(reports(j)).Count
                outputRow = outputRow + 1
            End If
        Next j
    Next g
    
    MsgBox "完成！结果已写入 Grouped Reports tab", vbInformation
End Sub


