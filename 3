SELECT
    COUNT(*) total_cnt,

    SUM(
        CASE
            WHEN triumphrefno IS NULL
             AND triumphrefno2 IS NULL
             AND triumphrefno_stg_id IS NULL
             AND triumphrefno2_stg_id IS NULL
            THEN 1
            ELSE 0
        END
    ) null_triumph_cnt

FROM if110_vec_productapp;


